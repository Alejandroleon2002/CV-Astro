---
import "../styles/global.css";
import Navigation from "./Navigation.astro";
import ThemeIcon from "./ThemeIcon.astro";
import { Image } from "astro:assets";
---

<header class="cabecera">
  <Navigation />
  <Image
    class="h-20 w-20 rounded-full bg-[#E1DCC9] dark:bg-[#002d47] dark:invert dark:hue-rotate-180 min-[480px]:h-[100px] min-[480px]:w-[100px] md:h-[120px] md:w-[120px]"
    src="/FotoGitHub.svg"
    alt="Foto perfil"
    width="120"
    height="120"
    loading="eager"
    decoding="async"
  />
  <div class="text-center">
    <ThemeIcon />
  </div>
</header>
