---
import "../styles/global.css";
---

<nav class="navegacion">
    <a class="linea" href="/">Inicio</a>
    <a class="linea" href="/estudios/">Estudios</a>
    <a class="linea" href="/practicas/">Prácticas</a>
    <a class="linea" href="/contacto/">Contacto</a>
</nav>

<style>
    nav {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 5px;
    }

    a {
        padding: 10px 15px;
        font-size: clamp(0.8rem, 2vw, 1rem);
        text-transform: uppercase;
        text-decoration: none;
        color: inherit;
        transition:
            background-color 0.5s ease,
            box-shadow 0.5s ease;
    }

    .linea {
        border-right: 1px solid currentColor;
        margin-right: 10px;
    }

    a:hover {
        background-color: rgba(177, 173, 168, 0.7);
        box-shadow: 0 0 15px rgba(177, 173, 168, 1);
        border-radius: 12px;
    }

    @media (max-width: 768px) {
        nav {
            width: 100%;
        }

        a {
            padding: 8px 12px;
            font-size: 0.9rem;
        }

        .linea {
            margin-right: 5px;
        }
    }
</style>
