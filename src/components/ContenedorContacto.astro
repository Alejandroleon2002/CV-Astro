---
const { plataforma, usuario, Icon } = Astro.props;
---

<a href={`https://www.${plataforma}.com/${usuario}`}>
    {Icon ? <Icon class="contact-icon" /> : null}
    {plataforma}
</a>

<style>
    a {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.25rem;
        background-color: #978f66;
        text-decoration: none;
        border-radius: 10px;
        color: white;
        font-size: 1.5rem;
        transition:
            background-color 0.4s ease,
            transform 0.4s ease;
    }

    .contact-icon {
        width: 24px;
        height: 24px;
        color: white;
        stroke: currentColor;
        flex-shrink: 0;
    }

    a:hover {
        background-color: #978f66;
        text-decoration: none;
        border-radius: 10px;
        color: white;
        transform: translateY(-10px);
    }
</style>
