---
const { plataforma, usuario, Icon } = Astro.props;
---
<a class="inline-flex items-center gap-3 rounded-[10px] bg-[#978F66] px-5 py-4 text-2xl text-white no-underline transition-all duration-500 hover:rounded-[10px] hover:bg-[#978F66] hover:text-[2rem] hover:text-white hover:no-underline" href={`https://www.${plataforma}.com/${usuario}`}>
    {Icon ? <Icon class="h-6 w-6 shrink-0 text-white" /> : null}
    {plataforma}
</a>

<style>
    a{
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.25rem;
        background-color: #978F66;
        text-decoration: none;
        border-radius: 10px;
        color: white;
        font-size: 1.5rem;
    }

    .contact-icon {
        width: 24px;
        height: 24px;
        color: white;
        stroke: currentColor;
        flex-shrink: 0;
    }

    a:hover{
        background-color: #978F66;
        text-decoration: none;
        border-radius: 10px;
        color: white;
        font-size: 2rem;
        transition: all 0.4s ease;
    }
</style>
