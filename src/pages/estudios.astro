---
import LayoutBasico from "../layouts/LayoutBasico.astro";
import "../styles/global.css";
const pageTitle = "CV Alejandro";
const titleClass =
    "mx-2.5 my-[15px] w-full max-w-[1200px] px-5 text-center text-[clamp(1.5rem,4vw,2rem)] uppercase text-black transition-colors duration-300 sm:mx-auto sm:my-5 dark:text-white";
const itemClass = "my-[15px] flex flex-col text-center sm:my-5";
const itemTitleClass = "text-center text-[clamp(1rem,2vw,1.3rem)] font-bold";
const textClass =
    "mx-auto my-2.5 w-full max-w-[1000px] px-[15px] text-center text-black transition-colors duration-300 sm:my-5 sm:px-5 dark:text-white";
---

<LayoutBasico pageTitle={pageTitle}>
    <h1 class="titulos">EDUCACIÓN</h1>
    <div>
        <div class="educacion">
            <h2 class="negrita estudio">Máster Desarrollador FullStack</h2>
            <p>MasterD, Madrid | Actualmente</p>
        </div>
        <div class="educacion">
            <h2 class="negrita estudio">
                Confección y Publicación de Páginas Web
            </h2>
            <p>Core Networks, Madrid | Actualmente</p>
        </div>
        <div class="educacion">
            <h2 class="negrita estudio">
                Grado Superior en Desarrollo de Aplicaciones Web (DAW)
            </h2>
            <p>I.E.S. Enrique Tierno Galván, Madrid | 2024 - 2025</p>
        </div>
        <div class="educacion">
            <h2 class="negrita estudio">
                Grado Superior en Desarrollo de Aplicaciones Multiplataforma
                (DAM)
            </h2>
            <p>I.E.S. Enrique Tierno Galván, Madrid | 2022 - 2024</p>
        </div>
        <div class="educacion">
            <h2 class="negrita estudio">
                Grado Medio en Sistemas Microinformáticos y Redes (SMR)
            </h2>
            <p>I.S.E.P. CEU, Madrid | 2019 - 2021</p>
        </div>
    </div>
    <hr />
</LayoutBasico>
